generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = env("DATABASE_PROVIDER", "sqlite")
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  height    Float?
  weightGoal  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  activities Activity[]
  dietRecords DietRecord[]
  weightRecords WeightRecord[]
  foods Food[]
}

// 运动记录表
model Activity {
  id              String   @id @default(uuid())
  userId          String
  type            String
  durationMinutes Int // 分钟
  caloriesBurned  Int
  distanceKm      Float? // 公里
  notes           String?
  date            DateTime
  createdAt       DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 饮食记录表
model DietRecord {
  id        String   @id @default(uuid())
  userId    String
  mealType  String // 早餐/午餐/晚餐/加餐
  foodName  String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  quantity  Float
  date      DateTime
  createdAt DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 食物表（系统默认食物 + 用户自定义食物）
model Food {
  id        String   @id @default(uuid())
  name      String
  caloriesPer100g Int
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  category  String
  isCustom  Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  // 关联
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 体重记录表
model WeightRecord {
  id                String   @id @default(uuid())
  userId            String
  weight            Float // 公斤
  bodyFatPercentage Float? // 百分比
  muscleMass        Float? // 公斤
  date              DateTime
  createdAt         DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
